# rattle — RattleScript shim. Forwards arguments to the affinescript CLI
# with --face rattle injected right after the subcommand. Source files
# should still use the canonical .affine extension and a face: rattlescript
# pragma; this shim only saves typing the --face flag for routine use.

if [ $# -eq 0 ]; then
  exec affinescript
fi
subcmd="$1"
shift
exec affinescript "$subcmd" --face rattle "$@"
